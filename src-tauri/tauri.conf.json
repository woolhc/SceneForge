{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SceneScript Desktop",
  "version": "0.1.0",
  "identifier": "com.scenescript.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:3100",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SceneScript Desktop",
        "width": 1440,
        "height": 940,
        "minWidth": 1024,
        "minHeight": 680,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPCACHE/**",
          "$DATA/**",
          "$CACHE/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
